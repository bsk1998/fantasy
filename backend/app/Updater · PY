#  MISE À JOUR BASE DE DONNÉES DEPUIS DONNÉES SCRAPPÉES
# ─────────────────────────────────────────────────────────────────────────────

def _sync_matchs_en_db(matchs: list, db) -> int:
    """
    Synchronise les scores des matchs dans la base de données.
    Retourne le nombre de matchs mis à jour.
    """
    from sqlalchemy import text

    mis_a_jour = 0
    for match in matchs:
        if not match.get("is_finished"):
            continue
        try:
            # Vérifier si la table match_results existe (optionnel)
            db.execute(
                text("""
                    INSERT OR REPLACE INTO match_results
                    (match_id, home_score, away_score, is_finished)
                    VALUES (:mid, :hs, :as, 1)
                """),
                {
                    "mid": match["id"],
                    "hs":  match.get("home_score"),
                    "as":  match.get("away_score"),
                }
            )
            mis_a_jour += 1
        except Exception:
            # La table n'existe pas encore — on ignore silencieusement
            pass

    return mis_a_jour


def _sync_effectifs_en_db(effectifs_nouveaux: list, db) -> int:
    """
    Insère ou met à jour les effectifs officiels en base de données.
    RÈGLE : Seuls les effectifs avec is_definitive=True sont insérés.
    Pour les équipes sans liste publiée, la BDD reste VIDE (ne rien faire).
    """
    inseres = 0
    for effectif in effectifs_nouveaux:
        if not effectif.get("is_definitive"):
            continue  # Règle critique : ne pas insérer les listes non officielles

        for joueur_data in effectif.get("joueurs", []):
            try:
                # Vérifier si le joueur existe déjà (par nom + nationalité)
                existing = db.query(Player).filter(
                    Player.name == joueur_data["name"],
                    Player.nationality == joueur_data["nationality"],
                ).first()

                if not existing:
                    nouveau_joueur = Player(
                        name=joueur_data["name"],
                        position=joueur_data["position"],
                        nationality=joueur_data["nationality"],
                        price=joueur_data.get("price", 6.0),
                        is_confirmed=True,
                        goals=0, assists=0, points_total=0,
                    )
                    db.add(nouveau_joueur)
                    inseres += 1
                else:
                    # Marquer comme confirmé si ce n'était pas le cas
                    existing.is_confirmed = True

            except Exception as e:
                logger.warning(f"Erreur insertion joueur {joueur_data.get('name')}: {e}")

    try:
        db.commit()
    except Exception as e:
        db.rollback()
        logger.error(f"Erreur commit effectifs : {e}")

    return inseres


# ─────────────────────────────────────────────────────────────────────────────
#  RECALCUL DES POINTS UTILISATEURS
# ─────────────────────────────────────────────────────────────────────────────

def _recalculer_points_tous_utilisateurs(db, matchs_termines: list) -> int:
    """
    Recalcule les points Fantasy et Pronostics pour tous les utilisateurs.
    Retourne le nombre d'utilisateurs mis à jour.
    """
    mis_a_jour = 0

    # Indexer les matchs terminés par leur ID pour accès rapide
    matchs_index = {
        m["id"]: m for m in matchs_termines
        if m.get("is_finished") and m.get("home_score") is not None
    }

    try:
        users = db.query(User).all()
    except Exception as e:
        logger.error(f"Impossible de récupérer les utilisateurs : {e}")
        return 0

    for user in users:
        try:
            # ── Recalcul Fantasy ──────────────────────────────────────────
            fantasy_pts = 0
            roster = db.query(FantasyRoster).filter(
                FantasyRoster.user_id == user.id
            ).first()
            if roster:
                fantasy_pts = sum((p.points_total or 0) for p in roster.players)
                if roster.coach:
                    fantasy_pts += (roster.coach.points_total or 0)
            user.score_fantasy = fantasy_pts

            # ── Recalcul Pronos Scores ────────────────────────────────────
            pronos = db.query(PredictionScore).filter(
                PredictionScore.user_id == user.id
            ).all()

            total_pronos_pts = 0
            for prono in pronos:
                match_reel = matchs_index.get(prono.match_id)
                if match_reel and RULES_AVAILABLE:
                    pts = calculer_points_pronostic_score(
                        prono.predicted_home_score,
                        prono.predicted_away_score,
                        match_reel["home_score"],
                        match_reel["away_score"],
                    )
                    if prono.points_earned != pts:
                        prono.points_earned = pts
                total_pronos_pts += (prono.points_earned or 0)

            user.score_predictor_scores = total_pronos_pts
            mis_a_jour += 1

        except Exception as e:
            logger.warning(f"Erreur recalcul user {user.id} : {e}")
            continue

    try:
        db.commit()
        logger.info(f"✅ Recalcul terminé : {mis_a_jour} utilisateurs mis à jour")
    except Exception as e:
        db.rollback()
        logger.error(f"Erreur commit recalcul : {e}")

    return mis_a_jour


# ─────────────────────────────────────────────────────────────────────────────
#  TÂCHE PRINCIPALE DE MISE À JOUR QUOTIDIENNE
# ─────────────────────────────────────────────────────────────────────────────

async def tache_mise_a_jour_quotidienne():
    """
    Tâche planifiée qui s'exécute chaque jour à 06:00 UTC.
    Orchestre : scraping → BDD → recalcul points → log.
    """
    global _derniere_mise_a_jour, _matchs_en_memoire, _classements_en_memoire
    global _statistiques_derniere_sync

    debut = time.time()
    logger.info(f"🔄 [{datetime.utcnow().isoformat()}] Début mise à jour quotidienne...")

    stats = {
        "matchs_scraped": 0,
        "joueurs_recalcules": 0,
        "effectifs_nouveaux": 0,
        "timestamp": datetime.utcnow().isoformat(),
        "erreurs": [],
    }

    try:
        # ── Étape 1 : Scraping toutes sources ────────────────────────────
        if SCRAPER_AVAILABLE:
            resultats = await scraping_complet()
            matchs      = resultats.get("matchs", [])
            classements = resultats.get("classements", {})
            effectifs   = resultats.get("effectifs", [])
            resume      = resultats.get("resume", {})

            # Mise à jour en mémoire (utilisée par les endpoints)
            _matchs_en_memoire    = matchs
            _classements_en_memoire = classements
            stats["matchs_scraped"] = resume.get("matchs_scraped", 0)
            stats["effectifs_nouveaux"] = len(effectifs)
        else:
            logger.warning("Scraper non disponible, mise à jour ignorée")
            matchs = []
            effectifs = []

        # ── Étape 2 : Synchronisation base de données ─────────────────────
        if DB_AVAILABLE and matchs:
            db = None
            try:
                db = SessionLocal()

                # Sync effectifs (si nouvelles listes publiées)
                if effectifs:
                    nb_inseres = _sync_effectifs_en_db(effectifs, db)
                    logger.info(f"📋 {nb_inseres} nouveaux joueurs insérés en BDD")

                # Recalcul points utilisateurs
                matchs_termines = [m for m in matchs if m.get("is_finished")]
                if matchs_termines or True:  # Toujours recalculer
                    nb_users = _recalculer_points_tous_utilisateurs(db, matchs_termines)
                    stats["joueurs_recalcules"] = nb_users

            except Exception as e:
                logger.error(f"❌ Erreur sync BDD : {e}")
                stats["erreurs"].append(str(e))
            finally:
                if db:
                    try:
                        db.close()
                    except Exception:
                        pass

        # ── Étape 3 : Mise à jour du timestamp ───────────────────────────
        _derniere_mise_a_jour = datetime.utcnow().isoformat()
        _statistiques_derniere_sync = stats

        duree = round(time.time() - debut, 2)
        logger.info(
            f"✅ Mise à jour terminée en {duree}s — "
            f"{stats['matchs_scraped']} matchs, "
            f"{stats['joueurs_recalcules']} users recalculés"
        )

    except Exception as e:
        logger.error(f"❌ Erreur fatale dans la tâche quotidienne : {e}")
        stats["erreurs"].append(f"Fatal: {str(e)}")
        _statistiques_derniere_sync = stats


# ─────────────────────────────────────────────────────────────────────────────
#  SYNC AU LOGIN UTILISATEUR (déclenchée par /auth/sync)
# ─────────────────────────────────────────────────────────────────────────────

async def sync_au_login(user_email: str, db) -> dict:
    """
    Sync légère déclenchée à chaque connexion utilisateur.
    Ne relance pas le scraping complet — utilise les données en cache.
    Recalcule uniquement les points de CET utilisateur.
    """
    logger.info(f"🔌 Sync login pour : {user_email}")

    # Utiliser les données en mémoire (mises à jour par la tâche quotidienne)
    matchs_disponibles = _matchs_en_memoire if _matchs_en_memoire else []
    matchs_termines = [m for m in matchs_disponibles if m.get("is_finished")]

    nb_pronos_recalcules = 0

    if DB_AVAILABLE and db:
        try:
            user = db.query(User).filter(User.email == user_email).first()
            if user and matchs_termines:
                nb_users = _recalculer_points_tous_utilisateurs(db, matchs_termines)
                nb_pronos_recalcules = nb_users
        except Exception as e:
            logger.warning(f"Sync login erreur : {e}")

    return {
        "matchs_en_memoire": len(matchs_disponibles),
        "matchs_termines":   len(matchs_termines),
        "pronos_calcules":   nb_pronos_recalcules,
        "derniere_maj":      _derniere_mise_a_jour,
    }


# ─────────────────────────────────────────────────────────────────────────────
#  DÉMARRAGE ET ARRÊT DU PLANIFICATEUR
# ─────────────────────────────────────────────────────────────────────────────

async def startup_handler():
    """
    Doit être appelé dans le lifespan FastAPI au démarrage de l'application.
    - Lance une première synchronisation immédiate (asynchrone, ne bloque pas)
    - Planifie la tâche quotidienne à 06:00 UTC
    """
    global _scheduler

    logger.info("🚀 Démarrage du moteur de mise à jour Fantasy Boulzazen...")

    # Première mise à jour en arrière-plan au démarrage (sans bloquer)
    asyncio.create_task(_premiere_sync())

    # Planification quotidienne
    if SCHEDULER_AVAILABLE:
        _scheduler = AsyncIOScheduler(timezone="UTC")
        _scheduler.add_job(
            tache_mise_a_jour_quotidienne,
            trigger=CronTrigger(hour=6, minute=0),
            id="maj_quotidienne",
            name="Mise à jour quotidienne WC 2026",
            replace_existing=True,
            max_instances=1,  # Empêche les exécutions simultanées
        )
        _scheduler.start()
        logger.info("✅ Planificateur APScheduler démarré (tâche quotidienne à 06:00 UTC)")
    else:
        logger.warning(
            "⚠️ APScheduler non disponible — installez apscheduler==3.10.4\n"
            "   La mise à jour automatique quotidienne est désactivée.\n"
            "   Utilisez POST /admin/recalculate pour forcer une mise à jour."
        )


async def _premiere_sync():
    """Première synchronisation légère au démarrage (ne scrape pas pour ne pas ralentir)."""
    await asyncio.sleep(5)  # Attendre que FastAPI soit pleinement démarré
    logger.info("🔄 Première synchronisation de démarrage...")
    try:
        await tache_mise_a_jour_quotidienne()
    except Exception as e:
        logger.error(f"Erreur première sync : {e}")


async def shutdown_handler():
    """
    Doit être appelé dans le lifespan FastAPI à l'arrêt de l'application.
    Arrête proprement le planificateur APScheduler.
    """
    global _scheduler
    if _scheduler and SCHEDULER_AVAILABLE:
        _scheduler.shutdown(wait=False)
        logger.info("🛑 Planificateur APScheduler arrêté proprement")


