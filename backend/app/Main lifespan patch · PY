    if UPDATER_AVAILABLE:
        from app.updater import get_matchs_actuels
        matchs_dynamiques = get_matchs_actuels()
        if matchs_dynamiques:
            return matchs_dynamiques

    # Fallback sur les données statiques définies dans main.py
    return MATCHS_CDM_2026
"""

