"""
main_lifespan_patch.py — Patch pour intégrer updater.py dans main.py

INSTRUCTIONS D'INTÉGRATION :
  1. Ajouter les imports ci-dessous au début de main.py
  2. Remplacer la ligne `app = FastAPI(...)` par la version avec lifespan
  3. Optionnel : ajouter la route /sync-status

Ce fichier n'est PAS exécuté directement — c'est une référence de code à copier.

FIX MULTIPROCESSING WINDOWS (Python 3.12+) :
  Le bug __firstlineno__ survient lors de l'utilisation de multiprocessing
  avec SQLAlchemy sous Windows. La solution est de forcer le mode 'spawn'
  et d'utiliser uniquement des processeurs async/await sans fork.
  APScheduler avec AsyncIOScheduler (asyncio) évite ce problème.
"""

# ══════════════════════════════════════════════════════════════════════════════
#  BLOC 1 — IMPORTS À AJOUTER EN TÊTE DE main.py (après les imports existants)
# ══════════════════════════════════════════════════════════════════════════════

IMPORTS_A_AJOUTER = """
from contextlib import asynccontextmanager

# Fix multiprocessing Windows Python 3.12+ : forcer le mode spawn
import multiprocessing
if multiprocessing.get_start_method(allow_none=True) is None:
    try:
        multiprocessing.set_start_method('spawn', force=False)
    except RuntimeError:
        pass  # Déjà initialisé — ignorer

try:
    from app.updater import startup_handler, shutdown_handler, get_stats_sync
    UPDATER_AVAILABLE = True
except ImportError:
    UPDATER_AVAILABLE = False
    logger.warning("updater.py non disponible — tâche de fond désactivée")
    async def startup_handler(): pass
    async def shutdown_handler(): pass
    def get_stats_sync(): return {"scheduler_actif": False}
"""

# ══════════════════════════════════════════════════════════════════════════════
#  BLOC 2 — REMPLACEMENT DE `app = FastAPI(...)` DANS main.py
#  Remplacer l'instanciation actuelle par celle-ci :
# ══════════════════════════════════════════════════════════════════════════════

APP_AVEC_LIFESPAN = """
@asynccontextmanager
async def lifespan(app: FastAPI):
    \"\"\"
    Gestionnaire de cycle de vie de l'application FastAPI.
    startup  : démarre APScheduler + première sync en arrière-plan
    shutdown : arrête proprement le planificateur
    \"\"\"
    logger.info("🟢 Démarrage de Fantasy Boulzazen API v4.2.0")
    await startup_handler()
    yield
    logger.info("🔴 Arrêt de Fantasy Boulzazen API")
    await shutdown_handler()


app = FastAPI(
    title="Fantasy Boulzazen — API WC 2026",
    description="Backend complet pour la ligue privée Fantasy Coupe du Monde",
    version="4.2.0",
    lifespan=lifespan,   # ← Nouveau : gestion startup/shutdown propre
)
"""

# ══════════════════════════════════════════════════════════════════════════════
#  BLOC 3 — NOUVELLE ROUTE /sync-status À AJOUTER DANS main.py
# ══════════════════════════════════════════════════════════════════════════════

ROUTE_SYNC_STATUS = """
