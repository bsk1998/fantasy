# ══════════════════════════════════════════════════════════════════════════════

ROUTE_MATCHES_DYNAMIQUE = """
@app.get("/matches")
async def get_matches():
    \"\"\"
    Retourne les matchs de la compétition.
    Priorité : données scrappées en mémoire > données statiques MATCHS_CDM_2026
